<Window x:Class="Com.Scm.Upgrade.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Upgrade.Net 更新"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Height="480" Width="560"
        Background="{StaticResource BgPrimary}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="16" Width="32" Height="32" CornerRadius="8" Background="{StaticResource AccentPrimary}">
                    <TextBlock Text="⟳" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TbTitle"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentPrimary}"
                               Margin="0,0,0,4"
                               Visibility="Collapsed"
                               Text="{Binding Content}"/>
                    <TextBlock FontSize="14" Foreground="{StaticResource TextSecondary}">应用升级程序</TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="16,8,16,8" CornerRadius="12" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="12,8,12,0" Padding="8,4" CornerRadius="6" Background="{StaticResource BgSecondary}">
                    <TextBlock Text="更新日志" FontSize="13" FontWeight="Medium" Foreground="{StaticResource AccentPrimary}"/>
                </Border>
                <TextBox Grid.Row="1"
                         x:Name="TbInfo"
                         Margin="12"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Text="{Binding Info}"
                         FontSize="13"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="16,0,16,8" CornerRadius="12" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColorBrush}" BorderThickness="1">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="TbStatus"
                           Grid.Row="0"
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimary}"
                           Margin="0,4,0,8"
                           Text="{Binding Status}"/>
                <ProgressBar x:Name="PbInfo"
                             Grid.Row="1"
                             Value="{Binding Ratio}"
                             Maximum="100"
                             Style="{StaticResource ModernProgressBar}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="BtStart"
                    Click="BtStart_Click"
                    Margin="8"
                    IsEnabled="{Binding Enabled}"
                    Style="{StaticResource ModernButtonStyle}">开始</Button>
            <Button x:Name="BtPause"
                    Click="BtPause_Click"
                    Margin="8"
                    IsEnabled="{Binding Enabled}"
                    Style="{StaticResource ModernButtonStyle}"
                    Tag="Secondary">暂停</Button>
            <Button x:Name="BtCancel"
                    Click="BtCancel_Click"
                    Margin="8"
                    Style="{StaticResource ModernButtonStyle}"
                    Tag="Danger">取消</Button>
        </StackPanel>
    </Grid>
</Window>
