<Window x:Class="Com.Scm.Upgrade.UpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade.Wpf 更新" 
        Height="640" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <!-- 核心：使用 WindowChrome 实现现代无边框 -->
    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="0" 
            ResizeBorderThickness="6" 
            GlassFrameThickness="0" 
            CornerRadius="8" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 中国蓝色板 -->
        <SolidColorBrush x:Key="ChinaBlue" Color="#2A6BC6"/>
        <SolidColorBrush x:Key="ChinaBlueLight" Color="#4A8AE8"/>
        <SolidColorBrush x:Key="ChinaBluePale" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="Vermilion" Color="#D94A4A"/>
        <SolidColorBrush x:Key="TextMain" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextSub" Color="#7A8B9E"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#38A169"/>
        <SolidColorBrush x:Key="CloseHover" Color="#E81123"/>
        <!-- 标准关闭悬停红 -->

        <!-- 按钮样式 -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ChinaBlueLight}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#A0B4CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource ChinaBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <!-- 外层 Border 用于绘制圆角和阴影 -->
    <Border Background="#F0F4F8" CornerRadius="8" BorderBrush="#D9E2EC" BorderThickness="1"
            Margin="6">
        <!-- Margin 给阴影和 ResizeBorder 留空间 -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="#2A6BC6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Body -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- 1. 自定义标题栏：支持拖拽 + 关闭按钮 -->
            <Border Grid.Row="0" Background="{StaticResource ChinaBlue}" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="32">
                    <TextBlock x:Name="TbTitle" Text="Upgrade.Wpf 更新" Foreground="White" FontSize="12" 
                               VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.9"/>

                    <!-- 关闭按钮 -->
                    <Button x:Name="BtCloseWindow" Content="✕" Width="46" Height="32" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="14" Cursor="Hand" Click="BtCloseWindow_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource CloseHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 2. 头部：应用信息 -->
            <Border Grid.Row="1" Background="{StaticResource ChinaBlue}" Padding="24,20,24,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="#33FFFFFF" CornerRadius="8" 
                            BorderBrush="#4DFFFFFF" BorderThickness="1">
                        <Image Source="{Binding Icon}" Width="32" Height="32" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="#E6FFFFFF" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 3. 主体内容 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <!-- 更新日志 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Rectangle Width="3" Height="14" Fill="{StaticResource Vermilion}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <TextBlock
                            Text="更新日志"
                            Foreground="{StaticResource ChinaBlue}"
                            FontSize="13"
                            FontWeight="Bold"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,0,0,24" Background="{StaticResource ChinaBluePale}" Padding="16,14,0,14" CornerRadius="0,6,6,0" 
                            BorderBrush="{StaticResource ChinaBlue}" BorderThickness="3,0,0,0" Height="120">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding VerInfo}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSub}"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 应用简介 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                        <Rectangle Width="3" Height="14" Fill="{StaticResource Vermilion}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                        <TextBlock
                            Text="应用简介"
                            Foreground="{StaticResource ChinaBlue}"
                            FontSize="13" 
                            FontWeight="Bold"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="3" Background="{StaticResource ChinaBluePale}" Padding="16,14,0,14" CornerRadius="0,6,6,0" 
                            BorderBrush="{StaticResource ChinaBlue}" BorderThickness="3,0,0,0"  Height="120">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Text="{Binding AppInfo}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSub}"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 进度条 -->
                    <StackPanel Grid.Row="4" x:Name="ProgressArea" Margin="0,20,0,0">
                        <ProgressBar
                            x:Name="PbInfo"
                            Height="4"
                            Foreground="{StaticResource ChinaBlue}" 
                            Background="#E2E8F0"
                            BorderThickness="0"
                            Maximum="100"
                            Value="{Binding Percent}"/>
                        <TextBlock
                            x:Name="TbInfo" 
                            Text="{Binding Notice}"
                            Foreground="{StaticResource TextSub}" 
                            FontSize="12"
                            Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- 4. 底部按钮区 -->
            <Border Grid.Row="3" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Background="#FAFBFC" Padding="16,24"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <StackPanel x:Name="SuccessStatus" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                        <Path Data="M 9,16.17 4.83,12 3.41,13.41 9,19 21,7 19.59,5.59 Z" 
                              Fill="{StaticResource SuccessGreen}" Width="24" Height="24" VerticalAlignment="Center"/>
                        <TextBlock Text="更新完成，重启后生效" Foreground="{StaticResource SuccessGreen}" 
                                   FontSize="13" FontWeight="Medium" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button
                            x:Name="BtLater"
                            Content="稍后提醒"
                            Style="{StaticResource SecondaryButton}" 
                            Margin="12,0,0,0"
                            Click="BtLater_Click"/>
                        <Button
                            x:Name="BtStart"
                            Content="立即更新"
                            Style="{StaticResource PrimaryButton}" 
                            Margin="12,0,0,0"
                            Click="BtStart_Click"/>
                        <Button
                            x:Name="BtLaunch"
                            Content="打开应用"
                            Style="{StaticResource SuccessButton}" 
                            Margin="12,0,0,0"
                            Click="BtLaunch_Click"
                            Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>