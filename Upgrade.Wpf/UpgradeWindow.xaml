<Window x:Class="Com.Scm.Upgrade.UpgradeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade.Wpf 更新" 
        Height="520" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        Closing="Window_Closing"
        AllowsTransparency="True">

    <!-- 核心：使用 WindowChrome 实现现代无边框 -->
    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="0" 
            ResizeBorderThickness="6" 
            GlassFrameThickness="0" 
            CornerRadius="8" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- 中国蓝色板 -->
        <SolidColorBrush x:Key="ChinaBlue" Color="#2A6BC6"/>
        <SolidColorBrush x:Key="ChinaBlueLight" Color="#4A8AE8"/>
        <SolidColorBrush x:Key="ChinaBluePale" Color="#E8F0FE"/>
        <SolidColorBrush x:Key="Vermilion" Color="#D94A4A"/>
        <SolidColorBrush x:Key="TextMain" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextSub" Color="#7A8B9E"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#38A169"/>
        <SolidColorBrush x:Key="CloseHover" Color="#E81123"/>
        <!-- 标准关闭悬停红 -->

        <!-- 按钮样式 -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource ChinaBlueLight}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#A0B4CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource ChinaBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <!-- 外层 Border 用于绘制圆角和阴影 -->
    <Border Background="#F0F4F8" CornerRadius="8" BorderBrush="#D9E2EC" BorderThickness="1"
            Margin="6">
        <!-- Margin 给阴影和 ResizeBorder 留空间 -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15" Color="#2A6BC6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- 自定义标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Body -->
                <RowDefinition Height="*"/>
                <!-- 进度条 -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 自定义标题栏：支持拖拽 + 关闭按钮 -->
            <Border Grid.Row="0" Background="{StaticResource ChinaBlue}" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="32">
                    <TextBlock x:Name="TbTitle" Text="Upgrade.Wpf 更新" Foreground="White" FontSize="12" 
                               VerticalAlignment="Center" Margin="12,0,0,0" Opacity="0.9"/>

                    <!-- 关闭按钮 -->
                    <Button x:Name="BtCloseWindow" Content="✕" Width="46" Height="32" 
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="14" Cursor="Hand" Command="{Binding CloseWindowCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource CloseHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- 2. 头部：应用信息 -->
            <Border Grid.Row="1" Background="{StaticResource ChinaBlue}" Padding="24,20,24,24">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="#33FFFFFF" CornerRadius="8" 
                            BorderBrush="#4DFFFFFF" BorderThickness="1">
                        <Image Source="{Binding Icon}" Width="32" Height="32" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Subtitle}" Foreground="#E6FFFFFF" FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 3. 主体内容 -->
            <Border Grid.Row="2" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：更新日志和应用简介 -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 更新日志 -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Rectangle Width="3" Height="14" Fill="{StaticResource Vermilion}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                <TextBlock
                                Text="更新日志"
                                Foreground="{StaticResource ChinaBlue}"
                                FontSize="13"
                                FontWeight="Bold"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Row="1" Margin="0,6,0,0" Background="{StaticResource ChinaBluePale}" Padding="16,14,0,14" CornerRadius="0,6,6,0" 
                                BorderBrush="{StaticResource ChinaBlue}" BorderThickness="3,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding VerInfo}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSub}"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <!-- 应用简介 -->
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <Rectangle Width="3" Height="14" Fill="{StaticResource Vermilion}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                                <TextBlock
                                Text="应用简介"
                                Foreground="{StaticResource ChinaBlue}"
                                FontSize="13" 
                                FontWeight="Bold"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Row="1" Margin="0,6,0,0" Background="{StaticResource ChinaBluePale}" Padding="16,14,0,14" CornerRadius="0,6,6,0" 
                                BorderBrush="{StaticResource ChinaBlue}" BorderThickness="3,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <TextBlock Text="{Binding AppInfo}" TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSub}"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- 右侧：升级步骤 -->
                    <Grid Grid.Column="1" Margin="12,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- 标题 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Rectangle Width="3" Height="14" Fill="{StaticResource Vermilion}" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
                            <TextBlock
                                Text="升级步骤"
                                Foreground="{StaticResource ChinaBlue}"
                                FontSize="13" 
                                FontWeight="Bold"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 步骤列表 -->
                        <Border Grid.Row="1" Margin="0,6,0,0" Background="{StaticResource ChinaBluePale}" Padding="16,14,0,14" CornerRadius="0,6,6,0" 
                                BorderBrush="{StaticResource ChinaBlue}" BorderThickness="3,0,0,0">
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Steps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock 
                                                    Grid.Column="0" 
                                                    Text="{Binding StatusIcon}" 
                                                    FontSize="14" 
                                                    Foreground="{Binding StatusColor}"
                                                    VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <TextBlock 
                                                    Text="{Binding Title}" 
                                                    FontSize="12" 
                                                    FontWeight="Medium"
                                                    Foreground="{StaticResource TextMain}"/>
                                                    <TextBlock 
                                                    Text="{Binding Message}" 
                                                    FontSize="11" 
                                                    Foreground="{Binding StatusColor}"
                                                    Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <TextBlock 
                                                    Grid.Column="2" 
                                                    Text="{Binding StepNumber}" 
                                                    FontSize="11" 
                                                    Foreground="{StaticResource TextSub}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- 进度条 -->
            <StackPanel Grid.Row="3" x:Name="ProgressArea" Margin="0">
                <ProgressBar
                    x:Name="PbInfo"
                    Height="4"
                    Foreground="{StaticResource ChinaBlue}" 
                    Background="#E2E8F0"
                    BorderThickness="0"
                    Maximum="100"
                    Value="{Binding Percent}"/>
            </StackPanel>

            <!-- 5. 底部按钮区 -->
            <Border Grid.Row="4" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Background="#FAFBFC" Padding="16,24"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <StackPanel x:Name="SuccessStatus" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Notice}" Foreground="{StaticResource SuccessGreen}" 
                                   FontSize="13" FontWeight="Medium" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button
                            x:Name="BtLater"
                            Content="稍后提醒"
                            Style="{StaticResource SecondaryButton}" 
                            Margin="12,0,0,0"
                            Command="{Binding LaterCommand}"
                            IsEnabled="{Binding LaterEnabled}"
                            Visibility="{Binding LaterVisibility}"/>
                        <Button
                            x:Name="BtStart"
                            Content="{Binding StartButtonText}"
                            Style="{StaticResource PrimaryButton}" 
                            Margin="12,0,0,0"
                            Command="{Binding StartCommand}"
                            IsEnabled="{Binding StartEnabled}"
                            Visibility="{Binding StartVisibility}"/>
                        <Button
                            x:Name="BtClose"
                            Content="退出"
                            Style="{StaticResource SuccessButton}" 
                            Margin="12,0,0,0"
                            Command="{Binding CloseCommand}"
                            IsEnabled="{Binding CloseEnabled}"
                            Visibility="{Binding CloseVisibility}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>